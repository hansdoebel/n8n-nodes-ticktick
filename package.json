		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"patchedDependencies": {
		"@n8n/node-cli@0.23.1": "patches/@n8n%2Fnode-cli@0.23.1.patch"
	}
}
